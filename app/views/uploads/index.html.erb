<p id="notice"><%= notice %></p>

<h1>Uploads</h1>

<div>
  <%= link_to 'New Upload', new_upload_path %>
</div>

<br />

<table>
  <thead>
    <tr>
      <th>Attachment</th>
      <th>Preview</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @uploads.each do |upload| %>
      <tr>
        <td><%= upload.attachment.id %></td>
        <td>
          <%= image_tag upload.attachment.preview(resize_to_limit: [100, 100]) if upload.attachment.previewable? %>
          <%= image_tag upload.attachment.variant(resize_to_limit: [100, 100]) if upload.attachment.variable? %>
        </td>
        <td><%= link_to 'Show', upload %></td>
        <td><%= link_to 'Edit', edit_upload_path(upload) %></td>
        <td><%= link_to 'Destroy', upload, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>
