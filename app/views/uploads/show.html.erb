<p id="notice"><%= notice %></p>

<p>
  <strong>Attachment:</strong>
  <%= link_to @upload.attachment.filename, @upload.attachment if @upload.attachment.attached? %>
</p>

<%= image_tag @upload.attachment.preview(resize_to_limit: [100, 100]) if @upload.attachment.previewable? %>
<%= image_tag @upload.attachment.variant(resize_to_limit: [100, 100]) if @upload.attachment.variable? %>

<%= link_to 'Edit', edit_upload_path(@upload) %> |
<%= link_to 'Back', uploads_path %>
